---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";

import CategoryList from "@/components/CategoryList.astro";
import PostArchive from "@/components/blog/PostArchive.astro";
import PageLayout from "@/layouts/Base.astro";
import { getAllPosts, getUniqueTagsWithCount, sortMDByDate } from "@/utils";

export const getStaticPaths = (async ({ paginate }) => {
	const allPosts = await getAllPosts();
	const allPostsByDate = sortMDByDate(allPosts);
	const tagsWithCount = getUniqueTagsWithCount(allPosts);
	// One page so posts group cleanly by year without spanning pages.
	return paginate(allPostsByDate, { pageSize: 500, props: { tagsWithCount } });
}) satisfies GetStaticPaths;

interface Props {
	page: Page<CollectionEntry<"post">>;
	tagsWithCount: Array<[string, number]>;
}

const { page, tagsWithCount } = Astro.props;

const meta = {
	description: "Ready my collection of posts and the things that interest me",
	title: "Posts",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-6">Posts</h1>
	<div class="grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8">
		<section aria-label="Blog post list">
			<PostArchive posts={page.data} withDesc />
		</section>
		{
			!!tagsWithCount.length && (
				<aside>
					<CategoryList
						hrefBase="/tags/"
						items={tagsWithCount}
						title="Categories"
						viewAllHref="/tags/"
					/>
				</aside>
			)
		}
	</div>
</PageLayout>
