---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";

import BookCard from "@/components/books/BookCard.astro";
import Pagination from "@/components/Paginator.astro";
import PageLayout from "@/layouts/Base.astro";
import { getAllBooks, getUniqueTagsBooks, sortMDByDateBooks } from "@/utils";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
	const allBooks = await getAllBooks();
	const allBooksByDate = sortMDByDateBooks(allBooks);
	const uniqueTags = getUniqueTagsBooks(allBooksByDate);

	return uniqueTags.flatMap((tag) => {
		const filtered = allBooksByDate.filter((book) => book.data.tags.includes(tag));
		return paginate(filtered, { pageSize: 60, params: { tag } });
	});
};

interface Props {
	page: Page<CollectionEntry<"book">>;
}

const { page } = Astro.props;
const { tag } = Astro.params;

const meta = {
	description: `Books in my library tagged ${tag}`,
	title: `Category: ${tag}`,
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: `← Previous`,
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			text: `Next →`,
			url: page.url.next,
		},
	}),
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-6 flex flex-wrap items-center gap-x-2">
		<a class="text-accent sm:hover:underline" href="/book-tags/">Categories</a>
		<span>→</span>
		<span class="text-xl">#{tag}</span>
		<span class="text-base font-normal text-textColor/50">{page.total}</span>
	</h1>
	<ul class="grid grid-cols-2 gap-x-5 gap-y-8 sm:grid-cols-3" role="list">
		{page.data.map((book) => <BookCard book={book} />)}
	</ul>
	<Pagination {...paginationProps} />
</PageLayout>
