---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "That page wandered off. Let's get you back to something worth reading.",
	title: "404 — Page not found",
};
---

<PageLayout meta={meta}>
	<section class="flex flex-col items-start">
		<p class="font-mono text-6xl font-bold text-accent">404</p>
		<h1 class="title mt-4">This page wandered off.</h1>
		<p class="mt-3 max-w-prose text-textColor/70">
			The link is broken or the page has moved. No worries — here's the way back.
		</p>
		<nav class="mt-6 flex flex-wrap gap-x-5 gap-y-2" aria-label="Helpful links">
			<a class="cactus-link" href="/">Home</a>
			<a class="cactus-link" href="/readme/">Readme</a>
			<a class="cactus-link" href="/posts/">Blog</a>
			<a class="cactus-link" href="/books/">Bookshelf</a>
		</nav>
	</section>
</PageLayout>
