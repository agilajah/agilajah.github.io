---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";

import PageLayout from "@/layouts/Base.astro";
import BookCard from "@/components/books/BookCard.astro";
import CategoryList from "@/components/CategoryList.astro";
import { spineData } from "../../data/spine-data";
import {
	getAllBooks,
	getUniqueTagsBooks,
	getUniqueTagsWithCountBooks,
	sortMDByDateBooks,
} from "@/utils";

export const getStaticPaths = (async ({ paginate }) => {
	const allBooks = await getAllBooks();
	const allBooksByDate = sortMDByDateBooks(allBooks);
	const uniqueTags = getUniqueTagsBooks(allBooks).sort((a, b) => a.localeCompare(b));
	const tagsWithCount = getUniqueTagsWithCountBooks(allBooks).sort((a, b) => b[1] - a[1]);
	// Status counts for the dashboard. Order: Read, Currently Reading, On Going, then any others.
	const order = ["Read", "Currently Reading", "On Going"];
	const counts = new Map<string, number>();
	for (const b of allBooks) counts.set(b.data.status, (counts.get(b.data.status) || 0) + 1);
	const statusStats = [...counts.entries()].sort(
		(a, b) => (order.indexOf(a[0]) + 1 || 99) - (order.indexOf(b[0]) + 1 || 99),
	);
	return paginate(allBooksByDate, {
		pageSize: 1000,
		props: { uniqueTags, statusStats, tagsWithCount, tagCount: uniqueTags.length },
	});
}) satisfies GetStaticPaths;

interface Props {
	page: Page<CollectionEntry<"book">>;
	uniqueTags: string[];
	statusStats: Array<[string, number]>;
	tagsWithCount: Array<[string, number]>;
	tagCount: number;
}

const { page, uniqueTags, statusStats, tagsWithCount, tagCount } = Astro.props;
const total = page.data.length;
const topTags = tagsWithCount.slice(0, 30);

const shelfYears = [];
for (const book of [...page.data]) {
	const year = book.data.publishDate.getFullYear();
	const last = shelfYears[shelfYears.length - 1];
	if (last && last[0] === year) last[1].push(book);
	else shelfYears.push([year, [book]]);
}
const spineHash = (sl) => [...sl].reduce((a, c) => a + c.charCodeAt(0), 0);
const spineH = (sl) => 15 + (spineHash(sl) % 8); // height 15-22 rem (varied)
// width tracks page count (thicker = longer book); fallback to a hashed width
const spineW = (sl) => {
	const pages = spineData[sl]?.pages;
	if (pages) return (1.55 + Math.min(1.9, (Math.max(90, pages) - 90) / 763 * 1.9)).toFixed(2);
	return (1.9 + (spineHash(sl) % 10) / 10).toFixed(2);
};
// cover accent hue/sat (0 sat = greyscale cover -> neutral spine)
const spineHue = (sl) => spineData[sl]?.hue ?? 0;
const spineSat = (sl) => spineData[sl]?.sat ?? 0;


const meta = {
	title: "Library",
	description: `A personal library of ${total} books — what I've read, am reading, and own.`,
};

const controlClass =
	"border border-textColor/20 bg-transparent px-3 py-2 text-sm text-textColor focus:border-accent focus:outline-none";
const statCell =
	"lib-stat flex min-w-[5rem] flex-1 flex-col items-start bg-bgColor px-3 py-2.5 text-left transition-colors hover:text-accent";
---

<PageLayout meta={meta}>
	<section>
		<div class="mb-12">
		<div class="mb-3 flex items-end justify-between gap-4">
			<nav class="year-nav flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-textColor/60" aria-label="Jump to year">
				{shelfYears.map(([year]) => (
					<a class="year-jump transition-colors hover:text-accent" data-year-jump={year} href={`#shelf-${year}`}>{year}</a>
				))}
			</nav>
			<div class="flex shrink-0 gap-1">
				<button aria-label="Scroll left" class="shelf-arrow" data-dir="-1" type="button">&lsaquo;</button>
				<button aria-label="Scroll right" class="shelf-arrow" data-dir="1" type="button">&rsaquo;</button>
			</div>
		</div>
		<div class="spine-shelf-wrap" id="spine-shelf-wrap">
		<div class="spine-shelf" id="spine-shelf">
			{shelfYears.map(([year, books]) => (
				<Fragment>
					<div class="year-divider" id={`shelf-${year}`}>
						<span class="year-label">{year} <span class="year-count">({books.length})</span></span>
					</div>
					{books.map((b) => (
						<a
							class="spine"
							data-author={b.data.author.toLowerCase()}
							data-cover={b.data.cover ?? ""}
							data-slug={b.slug}
							data-status={b.data.status}
							data-tags={b.data.tags.join(" ")}
							data-title={b.data.title.toLowerCase()}
							href={`/books/${b.slug}`}
							style={`--spine-h:${spineH(b.slug)}rem;--spine-w:${spineW(b.slug)}rem;--spine-hue:${spineHue(b.slug)};--spine-sat:${spineSat(b.slug)}%`}
							title={b.data.title}
						>
							<span class="spine-author">{b.data.author}</span>
							<span class="spine-title">{b.data.title}</span>
						</a>
					))}
				</Fragment>
			))}
		</div>
			<div class="shelf-hint" id="shelf-hint" aria-hidden="true">
				Scroll<span class="shelf-hint-arrow">&rarr;</span>
			</div>
		</div>

		</div>
		<div class="spine-preview" id="spine-preview" aria-hidden="true"><img alt="" decoding="async" /></div>
		<h1 class="title mb-2 flex items-baseline gap-3">
			Library
			<span class="text-base font-normal text-textColor/50">{total}</span>
		</h1>
		<p class="mb-8 max-w-2xl text-textColor/70">
			A running shelf of what I'm reading and have read. I love poking around other people's
			bookshelves — there's almost always a title or two I end up chasing down myself. If any of
			these catch your eye, or you have something I should read,
			<a class="cactus-link" href="mailto:febiagil@gmail.com">tell me about it.</a>
		</p>

		{/* ===== Control panel ===== */}
		<div class="mb-8 border border-textColor/15">
			{/* stats — status cells are clickable filters */}
			<div class="flex flex-wrap gap-px border-b border-textColor/15 bg-textColor/15">
				<button class={statCell} data-status="all" type="button">
					<span class="text-lg font-bold tabular-nums leading-none">{total}</span>
					<span class="lib-stat-label mt-1 text-[10px] font-medium uppercase tracking-widest text-textColor/50">
						Total
					</span>
				</button>
				{
					statusStats.map(([status, count]) => (
						<button class={statCell} data-status={status} type="button">
							<span class="text-lg font-bold tabular-nums leading-none">{count}</span>
							<span class="lib-stat-label mt-1 text-[10px] font-medium uppercase tracking-widest text-textColor/50">
								{status}
							</span>
						</button>
					))
				}
				<a
					class="flex min-w-[5rem] flex-1 flex-col items-start bg-bgColor px-3 py-2.5 transition-colors hover:text-accent"
					href="/book-tags/"
				>
					<span class="text-lg font-bold tabular-nums leading-none">{tagCount}</span>
					<span class="mt-1 text-[10px] font-medium uppercase tracking-widest text-textColor/50">
						Tags
					</span>
				</a>
			</div>

			{/* controls */}
			<div class="flex flex-wrap items-center gap-3 p-3">
				<input
					autocomplete="off"
					class:list={[controlClass, "w-full sm:w-auto sm:min-w-[12rem] sm:flex-1"]}
					id="lib-search"
					placeholder="Search title or author…"
					type="search"
				/>
				<select aria-label="Filter by category" class:list={[controlClass, "min-w-0 flex-1 sm:flex-none"]} id="lib-category">
					<option value="all">All categories</option>
					{uniqueTags.map((t) => <option value={t}>{t}</option>)}
				</select>
				<select aria-label="Sort books" class:list={[controlClass, "min-w-0 flex-1 sm:flex-none"]} id="lib-sort">
					<option value="recent">Newest first</option>
					<option value="oldest">Oldest first</option>
					<option value="title">Title A–Z</option>
					<option value="author">Author A–Z</option>
				</select>
				<div class="flex border border-textColor/20" role="group" aria-label="View">
					<button
						aria-label="Grid view"
						class="lib-view flex items-center justify-center px-3.5 py-3 text-textColor/70 transition-colors hover:text-accent"
						data-view="grid"
						type="button"
					>
						<svg aria-hidden="true" class="h-4 w-4" fill="currentColor" viewBox="0 0 16 16">
							<rect x="0" y="0" width="7" height="7"></rect>
							<rect x="9" y="0" width="7" height="7"></rect>
							<rect x="0" y="9" width="7" height="7"></rect>
							<rect x="9" y="9" width="7" height="7"></rect>
						</svg>
					</button>
					<button
						aria-label="List view"
						class="lib-view flex items-center justify-center px-3.5 py-3 text-textColor/70 transition-colors hover:text-accent"
						data-view="list"
						type="button"
					>
						<svg aria-hidden="true" class="h-4 w-4" fill="currentColor" viewBox="0 0 16 16">
							<rect x="0" y="1" width="16" height="2"></rect>
							<rect x="0" y="7" width="16" height="2"></rect>
							<rect x="0" y="13" width="16" height="2"></rect>
						</svg>
					</button>
					<button
						aria-label="By year"
						class="lib-view flex items-center justify-center px-3.5 py-3 text-textColor/70 transition-colors hover:text-accent"
						data-view="year"
						type="button"
					>
						<svg aria-hidden="true" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24">
							<rect x="3" y="4" width="18" height="17" rx="1.5"></rect>
							<path d="M3 9h18M8 2v4M16 2v4" stroke-linecap="round"></path>
						</svg>
					</button>
				</div>
			</div>
		</div>

		<div class="grid gap-y-10 sm:grid-cols-[1fr_15rem] sm:gap-x-8">
			<div class="min-w-0">
				<p class="mb-6 text-xs uppercase tracking-wider text-textColor/45">
					<span id="lib-count">{total}</span> of {total} books
				</p>

				<p class="hidden py-16 text-center text-textColor/50" id="lib-empty">
					No books match your filters.
				</p>

				<ul
					class="grid grid-cols-[repeat(auto-fill,minmax(6rem,1fr))] gap-x-4 gap-y-7"
					id="lib-grid"
					role="list"
				>
					{page.data.map((book) => <BookCard book={book} />)}
				</ul>
			</div>

			{/* Tag summary: right column on desktop, below on mobile (matches the blog) */}
			<aside>
				<CategoryList
					items={topTags}
					listId="lib-tagcloud"
					title="Top Categories"
					viewAllHref="/book-tags"
				/>
			</aside>
		</div>
	</section>
</PageLayout>

<script>
	function initLibrary() {
		const grid = document.getElementById("lib-grid");
		if (!grid) return; // not the library page

		const search = document.getElementById("lib-search") as HTMLInputElement;
		const categoryEl = document.getElementById("lib-category") as HTMLSelectElement;
		const sortEl = document.getElementById("lib-sort") as HTMLSelectElement;
		const countEl = document.getElementById("lib-count");
		const emptyEl = document.getElementById("lib-empty");
		const items = Array.from(grid.querySelectorAll<HTMLElement>(".lib-item"));
		const tagButtons = Array.from(document.querySelectorAll<HTMLElement>(".lib-tag"));
		const statButtons = Array.from(
			document.querySelectorAll<HTMLElement>(".lib-stat[data-status]"),
		);
		const viewButtons = Array.from(document.querySelectorAll<HTMLElement>(".lib-view"));
		const spines = Array.from(document.querySelectorAll<HTMLElement>(".spine"));
		const cardBySlug = new Map<string, HTMLElement>();
		items.forEach((el) => el.dataset.slug && cardBySlug.set(el.dataset.slug, el));

		let status = "all";
		let view = "grid";

		function sortKey(el: HTMLElement, mode: string) {
			if (mode === "title") return el.dataset.title || "";
			if (mode === "author") return el.dataset.author || "";
			return Number(el.dataset.date || 0); // recent / oldest
		}

		function apply() {
			const q = search.value.trim().toLowerCase();
			const cat = categoryEl.value;
			const mode = view === "year" ? "recent" : sortEl.value; // year view groups newest-first

			const sorted = items.slice().sort((a, b) => {
				const ka = sortKey(a, mode);
				const kb = sortKey(b, mode);
				if (mode === "title" || mode === "author") return String(ka).localeCompare(String(kb));
				const diff = Number(ka) - Number(kb);
				return mode === "oldest" ? diff : -diff;
			});

			// drop any year headers from a previous render
			grid.querySelectorAll(".lib-year-head").forEach((h) => h.remove());

			const matchEl = (el: HTMLElement) => {
				const matchQ =
					!q || (el.dataset.title || "").includes(q) || (el.dataset.author || "").includes(q);
				const matchS = status === "all" || el.dataset.status === status;
				const matchC = cat === "all" || (el.dataset.tags || "").split(" ").includes(cat);
				return matchQ && matchS && matchC;
			};

			// pass 1: which items show + per-year counts (for year-view headers)
			const yearCount = new Map<number, number>();
			let visible = 0;
			const shows = sorted.map((el) => {
				const show = matchEl(el);
				if (show) {
					visible++;
					const yr = new Date(Number(el.dataset.date || 0)).getFullYear();
					yearCount.set(yr, (yearCount.get(yr) || 0) + 1);
				}
				return show;
			});

			// pass 2: render (+ inject counted year headers in year view)
			let lastYear: number | null = null;
			sorted.forEach((el, i) => {
				if (view === "year" && shows[i]) {
					const yr = new Date(Number(el.dataset.date || 0)).getFullYear();
					if (yr !== lastYear) {
						const head = document.createElement("li");
						head.className = "lib-year-head";
						head.innerHTML = `${yr} <span class="lib-year-count">(${yearCount.get(yr) || 0})</span>`;
						grid.appendChild(head);
						lastYear = yr;
					}
				}
				grid.appendChild(el);
				el.style.display = shows[i] ? "" : "none";
			});

			if (countEl) countEl.textContent = String(visible);
			if (emptyEl) emptyEl.classList.toggle("hidden", visible > 0);
			tagButtons.forEach((b) => b.classList.toggle("is-active", b.dataset.tag === cat));
			statButtons.forEach((b) => b.classList.toggle("is-active", b.dataset.status === status));

			// interlink: dim shelf spines that don't match the active filters
			const filtering = q !== "" || status !== "all" || cat !== "all";
			spines.forEach((sp) => sp.classList.toggle("is-dim", filtering && !matchEl(sp)));
		}

		function setView(v: string) {
			view = v;
			grid.classList.toggle("is-list", v === "list");
			grid.classList.toggle("is-year", v === "year");
			viewButtons.forEach((b) => b.classList.toggle("is-active", b.dataset.view === v));
			try {
				localStorage.setItem("lib-view", v);
			} catch {}
			apply();
		}

		statButtons.forEach((btn) => {
			btn.addEventListener("click", () => {
				const s = btn.dataset.status || "all";
				status = status === s ? "all" : s;
				apply();
			});
		});
		tagButtons.forEach((btn) => {
			btn.addEventListener("click", () => {
				const tag = btn.dataset.tag || "";
				categoryEl.value = categoryEl.value === tag ? "all" : tag;
				apply();
			});
		});
		viewButtons.forEach((btn) => {
			btn.addEventListener("click", () => setView(btn.dataset.view || "grid"));
		});

		search.addEventListener("input", apply);
		categoryEl.addEventListener("change", apply);
		sortEl.addEventListener("change", apply);

		let savedView = "grid";
		try {
			savedView = localStorage.getItem("lib-view") || "grid";
		} catch {}
		setView(savedView); // calls apply()

		// ----- Browse shelf: arrows + year jump -----
		const shelf = document.getElementById("spine-shelf");
		if (shelf) {
			// reflect scroll position into edge-fade + hint affordances
			const wrap = document.getElementById("spine-shelf-wrap");
			shelf.scrollLeft = 0; // start at the most recent year
			const updateShelfCue = () => {
				if (!wrap) return;
				const max = shelf.scrollWidth - shelf.clientWidth;
				wrap.classList.toggle("more-left", shelf.scrollLeft > 8);
				wrap.classList.toggle("more-right", shelf.scrollLeft < max - 8);
			};
			shelf.addEventListener("scroll", () => {
				// retire the hint once the reader has scrolled a meaningful distance
				if (shelf.scrollLeft > 64) wrap?.classList.add("scrolled");
				updateShelfCue();
			}, { passive: true });
			window.addEventListener("resize", updateShelfCue, { passive: true });
			updateShelfCue();
			document.querySelectorAll(".shelf-arrow").forEach((btn) =>
				btn.addEventListener("click", () => {
					const dir = Number((btn as HTMLElement).dataset.dir);
					shelf.scrollBy({ left: dir * shelf.clientWidth * 0.8, behavior: "smooth" });
				}),
			);
			document.querySelectorAll(".year-jump").forEach((a) =>
				a.addEventListener("click", (e) => {
					e.preventDefault();
					const y = (a as HTMLElement).dataset.yearJump;
					document
						.getElementById("shelf-" + y)
						?.scrollIntoView({ behavior: "smooth", inline: "start", block: "nearest" });
				}),
			);
			// hovering a spine pops a floating cover preview (no scrolling)
			const preview = document.getElementById("spine-preview");
			const previewImg = preview?.querySelector("img") as HTMLImageElement | null;
			spines.forEach((sp) => {
				sp.addEventListener("mouseenter", () => {
					if (!preview || !previewImg) return;
					const cover = (sp as HTMLElement).dataset.cover;
					if (!cover) {
						preview.classList.remove("is-visible");
						return;
					}
					previewImg.src = `/assets/books/${cover}`;
					preview.classList.add("is-visible");
					const r = sp.getBoundingClientRect();
					const pw = preview.offsetWidth;
					const ph = preview.offsetHeight;
					const left = Math.max(8, Math.min(r.left + r.width / 2 - pw / 2, window.innerWidth - pw - 8));
					const top = r.top - ph - 10 < 8 ? r.bottom + 10 : r.top - ph - 10;
					preview.style.left = `${left}px`;
					preview.style.top = `${top}px`;
				});
				sp.addEventListener("mouseleave", () => preview?.classList.remove("is-visible"));
			});
		}
	}

	document.addEventListener("astro:page-load", initLibrary);
</script>
