---
import type { CollectionEntry } from "astro:content";

import "katex/dist/katex.min.css";

import type { SeriesInfo } from "@/utils";

import BlogHero from "@/components/blog/Hero.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import ReadingEnhancements from "@/components/blog/ReadingEnhancements.astro";
import SeriesNav from "@/components/blog/SeriesNav.astro";
import TOC from "@/components/blog/TOC.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";

import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post">;
	newer?: CollectionEntry<"post"> | null;
	older?: CollectionEntry<"post"> | null;
	series?: SeriesInfo | null;
	related?: Array<CollectionEntry<"post">>;
}

const { post, newer = null, older = null, series = null, related = [] } = Astro.props;
const {
	data: { description, ogImage, publishDate, title, updatedDate },
	slug,
} = post;
const socialImage = ogImage ?? `/og-image/${slug}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings } = await post.render();

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: title,
	description,
	datePublished: publishDate.toISOString(),
	dateModified: (updatedDate ?? publishDate).toISOString(),
	author: { "@type": "Person", name: "Febi Agil", url: Astro.site?.href },
	image: new URL(socialImage, Astro.site).href,
	url: canonical,
	mainEntityOfPage: canonical,
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<BaseLayout meta={{ articleDate, description, ogImage: socialImage, title }}>
	<ReadingEnhancements />
	<div class="lg:flex lg:items-start lg:justify-center lg:gap-x-8">
		<article class="w-full min-w-0 break-words lg:max-w-prose" data-pagefind-body>
			{!!headings.length && <TOC headings={headings} variant="float" />}
			<div id="blog-hero"><BlogHero content={post} /></div>
			{series && <div class="mt-10"><SeriesNav series={series} /></div>}
			<div
				class="prose prose-sm prose-cactus mt-12 prose-headings:font-semibold prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-accent prose-headings:before:content-['#'] prose-th:before:content-none"
			>
				<slot />
				<WebMentions />
			</div>
			{
				related.length > 0 && (
					<section class="mt-16 border-t border-textColor/10 pt-8">
						<h2 class="text-xs font-bold uppercase tracking-widest text-textColor/50">Related</h2>
						<ul class="mt-4 space-y-3">
							{related.map((p) => (
								<li class="group flex flex-wrap items-baseline gap-x-3">
									<a
										class="link-underline font-medium text-accent-2 transition-colors group-hover:text-accent"
										href={`/posts/${p.slug}/`}
									>
										{p.data.title}
									</a>
									<FormattedDate
										class="text-xs text-textColor/35"
										date={p.data.updatedDate ?? p.data.publishDate}
										dateTimeOptions={{ month: "short", year: "numeric" }}
									/>
								</li>
							))}
						</ul>
					</section>
				)
			}
			{
				(newer || older) && (
					<nav class="mt-16 flex flex-col gap-5 border-t border-textColor/10 pt-6 text-sm sm:flex-row sm:items-start sm:justify-between sm:gap-8">
						{older ? (
							<a
								class="group min-w-0 border-s-2 border-textColor/15 ps-3 transition-colors hover:border-accent sm:max-w-[47%] sm:border-s-0 sm:ps-0"
								href={`/posts/${older.slug}/`}
							>
								<div class="text-xs uppercase tracking-widest text-textColor/40">← Older</div>
								<div class="mt-1.5 line-clamp-2 text-textColor/70 transition-colors group-hover:text-accent">
									{older.data.title}
								</div>
							</a>
						) : (
							<span class="hidden sm:block" />
						)}
						{newer ? (
							<a
								class="group min-w-0 border-e-2 border-textColor/15 pe-3 text-end transition-colors hover:border-accent sm:max-w-[47%] sm:border-e-0 sm:pe-0"
								href={`/posts/${newer.slug}/`}
							>
								<div class="text-xs uppercase tracking-widest text-textColor/40">Newer →</div>
								<div class="mt-1.5 line-clamp-2 text-textColor/70 transition-colors group-hover:text-accent">
									{newer.data.title}
								</div>
							</a>
						) : (
							<span class="hidden sm:block" />
						)}
					</nav>
				)
			}
		</article>
		{!!headings.length && <TOC headings={headings} />}
	</div>
	<button
		aria-label="Back to Top"
		class="z-90 fixed bottom-8 end-4 flex h-10 w-10 translate-y-28 items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all duration-300 hover:border-zinc-400 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 dark:bg-zinc-700 sm:end-8 sm:h-12 sm:w-12"
		data-show="false"
		id="to-top-btn"
		><svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BaseLayout>

<script>
	let observer: IntersectionObserver | undefined;

	function initToTop() {
		const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement | null;
		const targetHeader = document.getElementById("blog-hero") as HTMLDivElement | null;
		// Not a post page (elements get swapped out by view transitions) — clean up.
		if (!scrollBtn || !targetHeader) {
			observer?.disconnect();
			return;
		}

		scrollBtn.addEventListener("click", () => {
			document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
		});

		observer?.disconnect();
		observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				// only show the scroll to top button when the heading is out of view
				scrollBtn.dataset.show = (!entry.isIntersecting).toString();
			});
		});
		observer.observe(targetHeader);
	}

	// Re-run after each view-transition navigation (also fires on first load).
	document.addEventListener("astro:page-load", initToTop);
</script>
