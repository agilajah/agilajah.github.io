---
// Year marker on the shared timeline rail. Edgy/brutalist treatment: a
// rotated accent square ("diamond") with a neon glow + a connector tick into
// the rail, distinct from the smaller hollow event nodes in TimelineItem.
interface Props {
	year: string | number;
	first?: boolean;
}

const { year, first = false } = Astro.props;
---

<div class:list={["relative mb-6", !first && "mt-14"]} data-reveal>
	{/* connector tick from the rail */}
	<span class="absolute start-[-2rem] top-[15px] h-px w-6 bg-accent/60"></span>
	{/* diamond node with accent glow */}
	<span
		class="absolute start-[-2rem] top-[9px] h-3.5 w-3.5 -translate-x-1/2 rotate-45 bg-accent ring-4 ring-bgColor shadow-[0_0_12px_2px_hsl(var(--theme-accent)/0.55)]"
	></span>
	<h2 class="text-2xl font-bold uppercase tracking-tight text-accent-2">{year}</h2>
</div>
