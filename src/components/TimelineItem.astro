---
import type { HTMLTag } from "astro/types";

interface Props {
	as?: HTMLTag;
	desc?: string;
	eventDate?: any;
	title?: string;
	withDesc?: boolean;
	linkSource?: string;
}

const { eventDate, title, desc, as: Element = "div", linkSource = "" } = Astro.props;
const date = new Date(eventDate).toDateString();
---

<Element class="group relative mb-7 last:mb-0" data-reveal>
	{/* connector tick — lights up accent on row hover */}
	<span
		class="absolute start-[-2rem] top-[9px] h-px w-5 bg-textColor/20 transition-colors duration-300 group-hover:bg-accent"
	></span>
	{/* hollow diamond node — fills accent + glows on hover */}
	<span
		class="absolute start-[-2rem] top-1 h-2 w-2 -translate-x-1/2 rotate-45 border border-textColor/50 bg-bgColor ring-2 ring-bgColor transition-all duration-300 group-hover:border-accent group-hover:bg-accent group-hover:shadow-[0_0_8px_1px_hsl(var(--theme-accent)/0.55)]"
	></span>

	<time datetime={date} class="text-xs font-medium uppercase tracking-wider text-textColor/50">
		{date}
	</time>

	<h3 class="mt-1 font-semibold leading-snug text-accent-2">{title}</h3>
	{desc && <p class="mt-1 text-textColor/70">{desc}</p>}

	{
		linkSource && (
			<a
				class="group/link mt-3 inline-flex items-center gap-2 border border-textColor/30 px-3 py-1.5 text-[11px] font-bold uppercase tracking-widest text-textColor transition-all duration-200 hover:border-accent hover:bg-accent hover:text-bgColor"
				data-magnetic
				href={linkSource}
				rel="noopener noreferrer"
				target="_blank"
			>
				Learn more
				<span aria-hidden="true" class="transition-transform duration-300 group-hover/link:translate-x-1">
					→
				</span>
			</a>
		)
	}
</Element>
