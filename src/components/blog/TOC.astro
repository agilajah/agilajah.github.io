---
import type { MarkdownHeading } from "astro";

import { generateToc } from "src/utils/generateToc";

import TOCHeading from "./TOCHeading.astro";

interface Props {
	headings: MarkdownHeading[];
	variant?: "desktop" | "float";
}

const { headings, variant = "desktop" } = Astro.props;

const toc = generateToc(headings);
---

{
	variant === "float" ? (
		/* Floating TOC for screens below the sidebar breakpoint: a button that
		   opens a contents panel. Sits just above the back-to-top button. */
		<details class="toc group/toc fixed bottom-24 end-4 z-40 lg:hidden sm:bottom-28 sm:end-8">
			<summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-full border-2 border-textColor/20 bg-bgColor text-textColor transition-colors hover:border-accent hover:text-accent sm:h-12 sm:w-12">
				<svg
					aria-hidden="true"
					class="h-5 w-5"
					fill="none"
					stroke="currentColor"
					stroke-linecap="round"
					stroke-width="1.8"
					viewBox="0 0 24 24"
				>
					<path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" />
				</svg>
				<span class="sr-only">Table of contents</span>
			</summary>
			<nav class="absolute bottom-14 end-0 max-h-[60vh] w-64 overflow-auto border border-textColor/15 bg-bgColor p-4 shadow-xl">
				<h2 class="text-xs font-bold uppercase tracking-widest text-textColor/50">Table of Contents</h2>
				<ul class="mt-3 text-xs">
					{toc.map((heading) => (
						<TOCHeading heading={heading} />
					))}
				</ul>
			</nav>
		</details>
	) : (
		<aside class="toc order-2 hidden shrink-0 basis-52 lg:sticky lg:top-20 lg:block">
			<h2 class="text-xs font-bold uppercase tracking-widest text-textColor/50">Table of Contents</h2>
			<ul class="mt-3 text-xs">
				{toc.map((heading) => (
					<TOCHeading heading={heading} />
				))}
			</ul>
		</aside>
	)
}
