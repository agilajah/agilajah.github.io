---
// Reveals elements tagged [data-reveal] as they scroll into view.
// Styling lives in src/styles/global.css (html.reveal-ready [data-reveal]).
// Gated by the reveal-ready class so no-JS / unsupported visitors see all
// content immediately — nothing is ever left permanently hidden.
---

<script>
	function initReveal() {
		const els = document.querySelectorAll<HTMLElement>("[data-reveal]:not(.is-visible)");
		if (!els.length) return;

		const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		if (reduce || !("IntersectionObserver" in window)) {
			els.forEach((el) => el.classList.add("is-visible"));
			return;
		}

		const io = new IntersectionObserver(
			(entries, obs) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;
					entry.target.classList.add("is-visible");
					obs.unobserve(entry.target);
				});
			},
			{ rootMargin: "0px 0px -10% 0px", threshold: 0.05 },
		);
		els.forEach((el) => io.observe(el));
	}

	// Add the gate class before first paint so reveal elements start hidden
	// (avoids a flash of the final state). Then (re)scan on every page load,
	// which also fires after each Astro view-transition navigation.
	document.documentElement.classList.add("reveal-ready");
	document.addEventListener("astro:page-load", initReveal);
</script>
