---
import type { CollectionEntry } from "astro:content";

interface Props {
	book: CollectionEntry<"book">;
}

const { book } = Astro.props;
const { title, author, cover, status, tags } = book.data;

// "Read" stands out (accent); everything else is muted.
const isRead = status?.toLowerCase() === "read";
---

<li
	class="lib-item group"
	data-author={author.toLowerCase()}
	data-date={book.data.publishDate.getTime()}
	data-status={status}
	data-tags={tags.join(" ")}
	data-title={title.toLowerCase()}
>
	<a class="lib-card-link block focus:outline-none" href={`/books/${book.slug}`}>
		<div
			class="book-cover relative aspect-[2/3] overflow-hidden bg-textColor/5 ring-1 ring-textColor/10 transition-all duration-300 group-hover:-translate-y-1.5 group-hover:ring-accent group-hover:shadow-[0_10px_28px_-10px_hsl(var(--theme-accent)/0.55)] group-focus-visible:ring-accent"
		>
			{
				cover ? (
					<img
						alt={`Cover of ${title}`}
						class="h-full w-full object-cover"
						height="300"
						loading="lazy"
						src={`/assets/books/${cover}`}
						width="200"
					/>
				) : (
					<div class="flex h-full items-center justify-center p-3 text-center text-xs font-semibold text-textColor/50">
						{title}
					</div>
				)
			}
			<span
				class:list={[
					"absolute end-1.5 top-1.5 px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wider backdrop-blur-sm",
					isRead ? "bg-accent text-bgColor" : "bg-bgColor/80 text-textColor/70",
				]}
			>
				{status}
			</span>
		</div>
		<div class="book-meta">
			<h3 class="book-title mt-2 line-clamp-2 text-xs font-semibold leading-snug text-accent-2">
				{title}
			</h3>
			<p class="book-author mt-0.5 line-clamp-1 text-xs text-textColor/55">{author}</p>
		</div>
		{/* shown only in list view */}
		<span class="book-status hidden text-[10px] font-bold uppercase tracking-wider text-textColor/40">
			{status}
		</span>
	</a>
</li>
