---
// Shared category/tag chip list used by both the blog (links to tag pages)
// and the library sidebar (client-side filter buttons). One source of truth
// so the two stay visually identical.
interface Props {
	title?: string;
	items: Array<[string, number]>;
	// When set, chips are links to `${hrefBase}${tag}/`. When omitted, chips are
	// filter buttons (class `lib-tag` + data-tag) wired up by the Library script.
	hrefBase?: string;
	viewAllHref?: string;
	viewAllLabel?: string;
	listId?: string;
}

const {
	title = "Categories",
	items,
	hrefBase,
	viewAllHref,
	viewAllLabel = "All categories →",
	listId,
} = Astro.props;

// Casual accent pills (rounded, solid) — the library's filter buttons get an
// inverted "active" look via .lib-tag.is-active in global.css.
const chip =
	"inline-flex items-center gap-1 rounded-md bg-accent px-2 py-0.5 text-xs text-bgColor transition-opacity hover:opacity-80";
---

<div>
	{title && <h2 class="mb-3 text-lg font-semibold">{title}</h2>}
	<ul class="flex flex-wrap gap-1.5" id={listId}>
		{
			items.map(([tag, count]) =>
				hrefBase ? (
					<li>
						<a class={chip} href={`${hrefBase}${tag}/`}>
							{tag}
							<span class="text-bgColor/60">{count}</span>
						</a>
					</li>
				) : (
					<li>
						<button class={`lib-tag ${chip}`} data-tag={tag} type="button">
							{tag}
							<span class="text-bgColor/60">{count}</span>
						</button>
					</li>
				),
			)
		}
	</ul>
	{
		viewAllHref && (
			<a
				class="mt-3 inline-block text-xs text-textColor/50 transition-colors hover:text-accent"
				href={viewAllHref}
			>
				{viewAllLabel}
			</a>
		)
	}
</div>
